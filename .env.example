# memory-neo/.env.example
# Path: .env.example
# Purpose: Environment variable template — copy to .env and fill in values
# Used by: FastAPI backend (api/)

# ── Memgraph (Fly.io hosted) ────────────────────────────────────────────────
MEMGRAPH_HOST=memgraph-app.internal   # Fly.io internal DNS
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=                    # leave empty if no auth configured
MEMGRAPH_PASSWORD=

# ── PostgreSQL (Supabase) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/memoryneo

# ── Claude API (Anthropic) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── API Security ────────────────────────────────────────────────────────────
API_SECRET_SALT=changeme_openssl_rand_base64_32

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production                # development | production
API_BASE_URL=https://api.memory-neo.dev
